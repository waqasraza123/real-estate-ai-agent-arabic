# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# API
API_HOST=0.0.0.0
API_PORT=4000
API_DATABASE_PATH=apps/api/.data/phase2-alpha
# Client-managed WhatsApp webhook credentials. Safe to leave unset until a real client is onboarding.
API_META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-meta-verify-token
API_META_WHATSAPP_APP_SECRET=replace-with-meta-app-secret
# Client-managed Google Calendar credentials. Safe to leave unset until a real client is onboarding.
API_GOOGLE_CALENDAR_ACCESS_TOKEN=replace-with-google-access-token
API_GOOGLE_CALENDAR_ID=replace-with-google-calendar-id

# Worker
WORKER_DATABASE_PATH=apps/api/.data/phase2-alpha
WORKER_BATCH_LIMIT=25
WORKER_POLL_INTERVAL_MS=15000
# Optional case-agent decision provider. Safe to leave unset; the worker falls back to deterministic policy.
WORKER_AGENT_OPENAI_API_KEY=
WORKER_AGENT_OPENAI_MODEL=gpt-5.4-mini
WORKER_AGENT_OPENAI_BASE_URL=https://api.openai.com/v1
WORKER_AGENT_OPENAI_TIMEOUT_MS=15000
# Client-managed Meta outbound credentials. Safe to leave unset until a real client is onboarding.
WORKER_META_WHATSAPP_ACCESS_TOKEN=replace-with-meta-access-token
WORKER_META_WHATSAPP_PHONE_NUMBER_ID=replace-with-meta-phone-number-id
WORKER_META_WHATSAPP_API_VERSION=v20.0
